# ── Database ──────────────────────────────────────────────────────────────────
# Docker ichida "db" — konteyner nomi
DATABASE_URL=postgresql://postgres:yourpassword@db:5432/evoting_db

# PostgreSQL (docker-compose env)
POSTGRES_DB=evoting_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=yourpassword

# ── Security ──────────────────────────────────────────────────────────────────
# Kamida 32 belgili tasodifiy kalit
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-min-32-chars-here

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production da frontend domenini kiriting
# Bir nechta: "https://example.com,https://www.example.com"
# Development uchun: *
ALLOWED_ORIGINS=*
